                                    <uuid>1e641e24312440b89e6092b19123ab32</uuid>
                                    <expression>(last(/hdd smart hels/physical.disk.rawww[{#DISKNAME},Reallocated_Sector_Ct],#1)&lt;&gt;last(/hdd smart hels/physical.disk.rawww[{#DISKNAME},Reallocated_Sector_Ct],#2))=1</expression>
                                    <name>{#DISKNAME} - Число переназначения секторов: {ITEM.LASTVALUE}</name>
                                    <priority>WARNING</priority>
                                </trigger_prototype>
                            </trigger_prototypes>
                        </item_prototype>
